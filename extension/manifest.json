{
  "manifest_version": 3,
  "name": "BridgeTab",
  "version": "0.1.0",
  "description": "Universal localhost browser bridge for controlled tab automation.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "BridgeTab",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}

